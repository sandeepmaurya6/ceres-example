<div class="advocate-bill">
  {{!-- Letterhead --}}
  <div class="no-dibella advocate-letterhead{{#unless invoice.letterHead}} is-empty{{/unless}}">
    {{#if invoice.letterHead}}
      <img src="{{invoice.letterHead}}" alt="Letterhead" data-ceres-height="letterhead" />
    {{else}}
      <img alt="Letterhead" data-ceres-height="letterhead" />
    {{/if}}
  </div>

  <div class="advocate-bill-container">

    {{!-- Header: Name, Title, Qualifications --}}
    <header class="advocate-header">
      <h1 class="advocate-name">{{invoice.billedBy.name}}</h1>
      <p class="advocate-title">{{invoice.invoiceTitle}}</p>
      {{#if invoice.invoiceSubTitle}}
        <p class="advocate-qualifications">{{invoice.invoiceSubTitle}}</p>
      {{/if}}
      <div class="header-divider"></div>
    </header>

    {{!-- Reference & Date row --}}
    <div class="ref-date-row">
      <div class="ref-number">
        {{#if invoice.customLabels.invoiceNumber}}{{invoice.customLabels.invoiceNumber}}{{else}}Ref{{/if}}: {{invoice.invoiceNumber}}
      </div>
      <div class="invoice-date">
        {{formateShortDateWithOffset invoice.invoiceDate invoice.ownerOffset}}
      </div>
    </div>

    {{!-- Billed To (Addressee) --}}
    <div class="addressee-section">
      <p>To,</p>
      <p><strong>{{invoice.billedTo.name}}</strong></p>
      {{#if invoice.billedTo.street}}
        <p>{{invoice.billedTo.street}}</p>
      {{/if}}
      {{#if invoice.billedTo.city}}
        <p>{{invoice.billedTo.city}}, {{invoice.billedTo.state}} {{invoice.billedTo.pincode}}</p>
      {{/if}}
    </div>

    {{!-- Subject line --}}
    {{#if invoice.notes}}
      <div class="subject-section">
        <p><strong>Subject:</strong> {{{invoice.notes}}}</p>
      </div>
    {{/if}}

    {{!-- Bill of Fees heading --}}
    <div class="bill-heading">
      <h2>BILL</h2>
    </div>

    {{!-- Line Items Table --}}
    <table class="bill-table">
      <thead>
        <tr>
          <th class="desc-col">DESCRIPTION</th>
          <th class="amount-col">AMOUNT [{{invoice.customCurrencySymbol}}]</th>
        </tr>
      </thead>
      <tbody>
        {{#each invoice.items}}
          <tr>
            <td class="desc-col">
              <span class="item-name">{{name}}</span>
              {{#if description}}
                <div class="item-description">
                  {{> MarkdownViewer (prepareMarkdownViewerData description) }}
                </div>
              {{/if}}
            </td>
            <td class="amount-col">
              {{../invoice.customCurrencySymbol}}{{subTotal}}
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    {{!-- Total row --}}
    <div class="total-section">
      <div class="total-row">
        <span class="total-label">
          {{#if invoice.customLabels.total}}{{invoice.customLabels.total}}{{else}}Total{{/if}}:
        </span>
        <span class="total-value">
          {{invoice.customCurrencySymbol}}{{invoice.finalTotal.total}}
        </span>
      </div>
      {{#if invoice.customLabels.totalInWordsValue}}
        <div class="total-words">
          <strong>[{{invoice.customLabels.totalInWordsValue}}]</strong>
        </div>
      {{/if}}
    </div>

    {{!-- Regards & Signature --}}
    <div class="regards-section">
      <p>Regards,</p>
      <div class="signature-block">
        <div class="signature-name">
          {{#if invoice.billedBy.signature}}
            <img class="signature-img" src="{{invoice.billedBy.signature}}" alt="Signature" />
          {{/if}}
          <p><strong>{{invoice.billedBy.name}}</strong></p>
        </div>

        {{!-- Bank Details --}}
        {{#if mapped.visibility.showBankAccount}}
          <div class="bank-details">
            {{#if invoice.bankAccount.holderName}}
              <p><em>Bank Account Name: {{invoice.bankAccount.holderName}}</em></p>
            {{/if}}
            {{#if invoice.bankAccount.bankName}}
              <p><em>Bank: {{invoice.bankAccount.bankName}}</em></p>
            {{/if}}
            {{#if invoice.bankAccount.accountType}}
              <p><em>Account Type: {{invoice.bankAccount.accountType}}</em></p>
            {{/if}}
            {{#with invoice.bankAccount}}
              {{#if accountNo}}
                <p><em>Account Number: {{accountNo}}</em></p>
              {{/if}}
              {{#if branch}}
                <p><em>Branch: {{branch}}</em></p>
              {{/if}}
              {{#if ifsc}}
                <p><em>IFSC/Swift Code: {{ifsc}}</em></p>
              {{/if}}
            {{/with}}
            {{#if invoice.billedBy.pan}}
              <p><em>PAN Number: {{invoice.billedBy.pan}}</em></p>
            {{/if}}
          </div>
        {{/if}}
      </div>
    </div>

    {{!-- Terms --}}
    {{#if invoice.terms.0.terms.length}}
      <div class="terms-section">
        <h3>{{#if invoice.customLabels.terms}}{{invoice.customLabels.terms}}{{else}}Terms and Conditions{{/if}}</h3>
        <ul>
          {{#each invoice.terms.0.terms}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    {{!-- Footer --}}
    <footer class="advocate-footer">
      <div class="footer-divider"></div>
      {{#if invoice.billedBy.street}}
        <p>{{invoice.billedBy.street}}, {{invoice.billedBy.city}}, {{invoice.billedBy.state}} {{invoice.billedBy.pincode}}</p>
      {{/if}}
      {{#if invoice.contact.phone}}
        <p>
          {{#if invoice.contact.email}}E-mail: {{invoice.contact.email}} | {{/if}}
          Mobile: {{invoice.contact.phone}}
        </p>
      {{/if}}
    </footer>

  </div>

  {{!-- Footer Letterhead --}}
  <div class="no-dibella advocate-letterhead-footer{{#unless invoice.letterHeadFooter}} is-empty{{/unless}}">
    {{#if invoice.letterHeadFooter}}
      <img src="{{invoice.letterHeadFooter}}" alt="Letterhead footer" data-ceres-height="letterhead-footer" />
    {{else}}
      <img alt="Letterhead footer" data-ceres-height="letterhead-footer" />
    {{/if}}
  </div>
</div>
