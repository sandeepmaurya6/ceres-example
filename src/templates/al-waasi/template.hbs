<div class="aw-shell">
  {{!-- Header Letterhead --}}
  <div class="no-dibella aw-letterhead{{#unless invoice.letterHead}} is-empty{{/unless}}">
    {{#if invoice.letterHead}}
    <img src="{{invoice.letterHead}}" alt="Letterhead" data-ceres-height="letterhead" />
    {{else}}
    <img alt="Letterhead" data-ceres-height="letterhead" />
    {{/if}}
  </div>

  <div class="aw-container">

    {{!-- Logo Bar --}}
    <div class="aw-logo-bar">
      <div class="aw-logo-wrap">
        {{#if invoice.billedBy.logo}}
        <img src="{{invoice.billedBy.logo}}" alt="{{invoice.billedBy.name}}" class="aw-logo" />
        {{/if}}
        <div>{{> DemoBadge }}</div>
      </div>
      <p class="aw-invoice-title">Tax Invoice</p>
    </div>

    {{!-- Row 1: Billed By | Buyer | Invoice Meta --}}
    <div class="aw-cards-row">
      <div class="aw-card">
        <p class="aw-card-label">Billed by</p>
        <div class="aw-card-content">
          <p class="aw-name">{{invoice.billedBy.name}}</p>
          <p class="aw-addr">{{invoice.billedBy.street}}{{#if invoice.billedBy.city}}, {{invoice.billedBy.city}}{{/if}}{{#if invoice.billedBy.pincode}} - {{invoice.billedBy.pincode}}{{/if}}</p>
          {{#if invoice.billedBy.phone}}<div class="aw-kv"><span class="aw-key">Phone:</span><span class="aw-val">{{invoice.billedBy.phone}}</span></div>{{/if}}
          {{#if invoice.billedBy.email}}<div class="aw-kv"><span class="aw-key">Email:</span><span class="aw-val">{{invoice.billedBy.email}}</span></div>{{/if}}
        </div>
      </div>

      <div class="aw-card">
        <p class="aw-card-label">Buyer</p>
        <div class="aw-card-content">
          <p class="aw-name">{{invoice.billedTo.name}}</p>
          <p class="aw-addr">{{invoice.billedTo.street}}{{#if invoice.billedTo.city}}, {{invoice.billedTo.city}}{{/if}}{{#if invoice.billedTo.pincode}} - {{invoice.billedTo.pincode}}{{/if}}</p>
          {{#if invoice.billedTo.gstin}}<div class="aw-kv"><span class="aw-key">GSTIN:</span><span class="aw-val">{{invoice.billedTo.gstin}}</span></div>{{/if}}
          {{#if invoice.billedTo.pan}}<div class="aw-kv"><span class="aw-key">DL NO:</span><span class="aw-val">{{invoice.billedTo.pan}}</span></div>{{/if}}
        </div>
      </div>

      <div class="aw-card aw-meta-card">
        <div class="aw-kv-grid">
          <span class="aw-key">Invoice #</span><span class="aw-val">{{invoice.invoiceNumber}}</span>
          <span class="aw-key">Invoice Date</span><span class="aw-val">{{formateShortDateWithOffset invoice.invoiceDate invoice.ownerOffset}}</span>
          {{#if invoice.dueDate}}
          <span class="aw-key">Due Date</span><span class="aw-val">{{formateShortDateWithOffset invoice.dueDate invoice.ownerOffset}}</span>
          {{/if}}
          {{#if invoice.customLabels.deliveryNote}}
          <span class="aw-key">Delivery Note</span><span class="aw-val">{{invoice.customLabels.deliveryNote}}</span>
          {{/if}}
          {{#if invoice.customLabels.destination}}
          <span class="aw-key">Destination</span><span class="aw-val">{{invoice.customLabels.destination}}</span>
          {{/if}}
          {{#if invoice.customLabels.termsOfDelivery}}
          <span class="aw-key">Terms of Delivery:-</span><span class="aw-val">{{invoice.customLabels.termsOfDelivery}}</span>
          {{/if}}
        </div>
      </div>
    </div>

    {{!-- Row 2: Shipped From | Shipped To | Transport Details --}}
    <div class="aw-cards-row">
      <div class="aw-card">
        <p class="aw-card-label">Shipped From</p>
        <div class="aw-card-content">
          <p class="aw-name">{{invoice.billedBy.name}}</p>
          <p class="aw-addr">{{invoice.billedBy.street}}{{#if invoice.billedBy.city}}, {{invoice.billedBy.city}}{{/if}}{{#if invoice.billedBy.pincode}} - {{invoice.billedBy.pincode}}{{/if}}</p>
          {{#if invoice.billedBy.phone}}<div class="aw-kv"><span class="aw-key">Phone:</span><span class="aw-val">{{invoice.billedBy.phone}}</span></div>{{/if}}
          {{#if invoice.billedBy.email}}<div class="aw-kv"><span class="aw-key">Email:</span><span class="aw-val">{{invoice.billedBy.email}}</span></div>{{/if}}
        </div>
      </div>

      <div class="aw-card">
        <p class="aw-card-label">Shipped To</p>
        <div class="aw-card-content">
          <p class="aw-name">{{invoice.billedTo.name}}</p>
          <p class="aw-addr">{{invoice.billedTo.street}}{{#if invoice.billedTo.city}}, {{invoice.billedTo.city}}{{/if}}{{#if invoice.billedTo.pincode}} - {{invoice.billedTo.pincode}}{{/if}}</p>
          {{#if invoice.billedTo.phone}}<div class="aw-kv"><span class="aw-key">Phone:</span><span class="aw-val">{{invoice.billedTo.phone}}</span></div>{{/if}}
          {{#if invoice.billedTo.email}}<div class="aw-kv"><span class="aw-key">Email:</span><span class="aw-val">{{invoice.billedTo.email}}</span></div>{{/if}}
        </div>
      </div>

      <div class="aw-card aw-meta-card">
        <p class="aw-card-label">Transport Details</p>
        <div class="aw-kv-grid aw-kv-grid-sm">
          {{#if invoice.customLabels.transportMode}}<span class="aw-key">Transport Mode:</span><span class="aw-val">{{invoice.customLabels.transportMode}}</span>{{/if}}
          {{#if invoice.customLabels.transporter}}<span class="aw-key">Transporter:</span><span class="aw-val">{{invoice.customLabels.transporter}}</span>{{/if}}
          {{#if invoice.customLabels.transporterId}}<span class="aw-key">Transporter ID:</span><span class="aw-val">{{invoice.customLabels.transporterId}}</span>{{/if}}
          {{#if invoice.customLabels.challanDate}}<span class="aw-key">Challan Date:</span><span class="aw-val">{{invoice.customLabels.challanDate}}</span>{{/if}}
          {{#if invoice.customLabels.challanNumber}}<span class="aw-key">Challan Number:</span><span class="aw-val">{{invoice.customLabels.challanNumber}}</span>{{/if}}
          {{#if invoice.customLabels.vehicleType}}<span class="aw-key">Vehicle Type:</span><span class="aw-val">{{invoice.customLabels.vehicleType}}</span>{{/if}}
          {{#if invoice.customLabels.vehicleNumber}}<span class="aw-key">Vehicle Number:</span><span class="aw-val">{{invoice.customLabels.vehicleNumber}}</span>{{/if}}
        </div>
      </div>
    </div>

    {{!-- Items Table + Totals --}}
    <div class="aw-table-block">
      <table class="aw-item-table">
        <thead>
          <tr>
            <th class="col-sno">#</th>
            <th class="col-item">Item</th>
            <th class="col-rate text-right">Rate</th>
            <th class="col-qty text-center">Qty</th>
            <th class="col-amount text-right">Amount</th>
            <th class="col-disc text-center">Discount</th>
            <th class="col-gst text-center">GST %</th>
            <th class="col-igst text-right">IGST</th>
            <th class="col-total text-right">Total</th>
          </tr>
        </thead>
        <tbody>
          {{#each invoice.items}}
          <tr>
            <td class="text-center aw-muted">{{increment @index}}</td>
            <td>
              <span class="item-name">{{name}}</span>
              {{#if description}}
              <div class="item-desc">{{description}}</div>
              {{/if}}
            </td>
            <td class="text-right aw-muted">{{../invoice.customCurrencySymbol}}{{rate}}</td>
            <td class="text-center aw-muted">{{quantity}}</td>
            <td class="text-right aw-muted">{{../invoice.customCurrencySymbol}}{{amount}}</td>
            <td class="text-center aw-muted">{{discountLabel}}</td>
            <td class="text-center aw-muted">{{taxLabel}}</td>
            <td class="text-right aw-muted">{{../invoice.customCurrencySymbol}}{{tax}}</td>
            <td class="text-right aw-muted">{{../invoice.customCurrencySymbol}}{{total}}</td>
          </tr>
          {{/each}}
        </tbody>
        <tfoot>
          <tr class="aw-tfoot-row">
            <td></td>
            <td class="aw-bold">Total</td>
            <td class="text-right aw-bold">{{invoice.customCurrencySymbol}}{{invoice.finalTotal.subTotal}}</td>
            <td class="text-center aw-bold">{{invoice.totalQuantity}}</td>
            <td class="text-right aw-bold">{{invoice.customCurrencySymbol}}{{invoice.finalTotal.subTotal}}</td>
            <td></td>
            <td></td>
            <td class="text-right aw-bold">{{invoice.customCurrencySymbol}}{{invoice.finalTotal.igst}}</td>
            <td class="text-right aw-bold">{{invoice.customCurrencySymbol}}{{invoice.finalTotal.total}}</td>
          </tr>
        </tfoot>
      </table>

      {{!-- Totals Box --}}
      <div class="aw-totals-box">
        {{#if invoice.finalTotal.discount}}
        <div class="aw-total-row">
          <div class="aw-total-spacer"></div>
          <div class="aw-total-label-cell aw-bold">Discount</div>
          <div class="aw-total-val-cell">{{invoice.customCurrencySymbol}} {{invoice.finalTotal.discount}}</div>
        </div>
        {{/if}}
        {{#if invoice.finalTotal.sgst}}
        <div class="aw-total-row">
          <div class="aw-total-spacer"></div>
          <div class="aw-total-label-cell aw-bold">{{#if mapped.visibility.isUtgst}}UTGST{{else}}SGST{{/if}}</div>
          <div class="aw-total-val-cell">{{invoice.customCurrencySymbol}} {{invoice.finalTotal.sgst}}</div>
        </div>
        {{/if}}
        {{#if invoice.finalTotal.cgst}}
        <div class="aw-total-row">
          <div class="aw-total-spacer"></div>
          <div class="aw-total-label-cell aw-bold">CGST</div>
          <div class="aw-total-val-cell">{{invoice.customCurrencySymbol}} {{invoice.finalTotal.cgst}}</div>
        </div>
        {{/if}}
        {{#if invoice.finalTotal.igst}}
        <div class="aw-total-row">
          <div class="aw-total-spacer"></div>
          <div class="aw-total-label-cell aw-bold">IGST</div>
          <div class="aw-total-val-cell">{{invoice.customCurrencySymbol}} {{invoice.finalTotal.igst}}</div>
        </div>
        {{/if}}
        <div class="aw-total-row aw-grand-row">
          <div class="aw-total-spacer"></div>
          <div class="aw-total-label-cell aw-bold aw-large">Total (INR)</div>
          <div class="aw-total-val-cell aw-bold aw-large">{{invoice.customCurrencySymbol}} {{invoice.finalTotal.total}}</div>
        </div>
        {{#if invoice.customLabels.totalInWordsValue}}
        <div class="aw-words-row">
          <span>Invoice Total (in words):</span>
          <span class="aw-bold">{{invoice.customLabels.totalInWordsValue}}</span>
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- Terms & Conditions + Bank Details --}}
    <div class="aw-cards-row aw-stretch-row">
      <div class="aw-card aw-terms-card">
        {{#if invoice.terms.0.terms.length}}
        <div class="aw-section-block">
          <p class="aw-section-title">Terms and Conditions</p>
          <ol class="aw-list">
            {{#each invoice.terms.0.terms}}
            <li>{{this}}</li>
            {{/each}}
          </ol>
        </div>
        {{/if}}
        {{#if invoice.customLabels.declaration}}
        <div class="aw-section-block">
          <p class="aw-section-title">Declaration</p>
          <p class="aw-muted aw-small">{{invoice.customLabels.declaration}}</p>
        </div>
        {{/if}}
      </div>

      {{#if mapped.visibility.showBankAccount}}
      <div class="aw-card aw-bank-card">
        <div class="aw-bank-inner">
          <div class="aw-bank-details">
            <div class="aw-section-block">
              <p class="aw-section-title">Bank and UPI details</p>
              <div class="aw-bank-kv">
                {{#if invoice.bankAccount.bankName}}<span class="aw-key">Bank Name</span><span class="aw-muted">{{invoice.bankAccount.bankName}}</span>{{/if}}
                <span class="aw-key">Account Holder Name</span>
                <span class="aw-muted">{{#if invoice.bankAccount.holderName}}{{invoice.bankAccount.holderName}}{{else}}{{invoice.billedBy.name}}{{/if}}</span>
                {{#if invoice.bankAccount.accountNo}}<span class="aw-key">Account Number</span><span class="aw-muted">{{invoice.bankAccount.accountNo}}</span>{{/if}}
                {{#if invoice.bankAccount.ifsc}}<span class="aw-key">IFSC</span><span class="aw-muted">{{invoice.bankAccount.ifsc}}</span>{{/if}}
              </div>
            </div>
            {{#if invoice.bankAccount.upiId}}
            <div class="aw-section-block">
              <p class="aw-section-title">UPI ID</p>
              <p class="aw-muted aw-small">{{invoice.bankAccount.upiId}}</p>
            </div>
            {{/if}}
          </div>
          {{#if invoice.bankAccount.qrCode}}
          <div class="aw-qr-block">
            <p class="aw-section-title text-center">Scan To Pay</p>
            <img src="{{invoice.bankAccount.qrCode}}" alt="Scan to Pay" class="aw-qr-img" />
            <p class="aw-muted aw-small text-center">Maximum of 1 lakh can be transferred via upi in a single day</p>
          </div>
          {{/if}}
        </div>
      </div>
      {{/if}}
    </div>

    {{!-- Additional Notes --}}
    {{#if invoice.notes}}
    <div class="aw-card aw-full-card">
      <p class="aw-section-title">Additional Notes</p>
      <div class="aw-muted aw-small">
        {{> MarkdownViewer (prepareMarkdownViewerData invoice.notes) }}
      </div>
    </div>
    {{/if}}

    {{!-- Additional Info + Signature --}}
    <div class="aw-cards-row aw-stretch-row">
      <div class="aw-card aw-additional-card">
        <p class="aw-section-title">Additional Information</p>
        {{#if invoice.billedBy.gstin}}
        <div class="aw-kv"><span class="aw-key aw-key-wide">Company's GST NO</span><span class="aw-val">{{invoice.billedBy.gstin}}</span></div>
        {{/if}}
        {{#if invoice.billedBy.pan}}
        <div class="aw-kv"><span class="aw-key aw-key-wide">Company's DL NO.</span><span class="aw-val">{{invoice.billedBy.pan}}</span></div>
        {{/if}}
        {{#if invoice.billedBy.cin}}
        <div class="aw-kv"><span class="aw-key aw-key-wide">Company's CIN</span><span class="aw-val">{{invoice.billedBy.cin}}</span></div>
        {{/if}}
      </div>

      <div class="aw-card aw-sig-card">
        {{#if invoice.billedBy.signature}}
        <img src="{{invoice.billedBy.signature}}" alt="Signature" class="aw-sig-img" />
        {{/if}}
        <p class="aw-bold aw-small">Authorised Signatory</p>
      </div>
    </div>

    <p class="aw-elec-notice">This is an electronically generated document, no signature is required.</p>

  </div>

  {{!-- Footer --}}
  <div class="aw-footer">
    <div class="aw-footer-inner">
      <div class="aw-sig-row">
        <div class="aw-sig-field">
          <div class="aw-sig-line"></div>
          <p class="aw-sig-label">Receiver's Signature / توقيع المستلم</p>
        </div>
        <div class="aw-sig-field aw-sig-center">
          <div class="aw-sig-line"></div>
          <p class="aw-sig-label text-center">Receiver's Name / اسم المستلم</p>
        </div>
        <div class="aw-sig-field">
          <div class="aw-sig-line"></div>
          <p class="aw-sig-label">Salesman Signature / توقيع البائع</p>
        </div>
      </div>
      <div class="aw-footer-notice">
        <span>BUYER MUST CHECK QUANTITY AND QUALITY AT THE TIME OF DELIVERY</span>
        <span dir="auto">يجب على المشتري التحقق من الكمية والجودة وقت التسليم.</span>
      </div>
    </div>
  </div>

  {{!-- Letterhead Footer --}}
  <div class="no-dibella aw-letterhead-footer{{#unless invoice.letterHeadFooter}} is-empty{{/unless}}">
    {{#if invoice.letterHeadFooter}}
    <img src="{{invoice.letterHeadFooter}}" alt="Letterhead footer" data-ceres-height="letterhead-footer" />
    {{else}}
    <img alt="Letterhead footer" data-ceres-height="letterhead-footer" />
    {{/if}}
  </div>
</div>
