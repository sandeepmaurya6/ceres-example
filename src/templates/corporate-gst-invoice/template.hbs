<div class="corp-gst-shell">
  {{!-- Letterhead --}}
  <div class="no-dibella corp-letterhead{{#unless invoice.letterHead}} is-empty{{/unless}}">
    {{#if invoice.letterHead}}
    <img src="{{invoice.letterHead}}" alt="Letterhead" data-ceres-height="letterhead" />
    {{else}}
    <img alt="Letterhead" data-ceres-height="letterhead" />
    {{/if}}
  </div>

  <div class="corp-gst-container">

    {{!-- Logo & Brand --}}
    <div class="corp-logo-bar">
      {{#if invoice.billedBy.logo}}
      <img src="{{invoice.billedBy.logo}}" alt="{{invoice.billedBy.name}}" class="corp-logo" />
      {{/if}}
      <div style="margin-top:4px">{{> DemoBadge }}</div>
    </div>

    {{!-- Invoice To / Contact Person --}}
    <div class="corp-address-row">
      <div class="corp-address-left">
        <p class="corp-label">{{#if invoice.customLabels.billedTo}}{{invoice.customLabels.billedTo}}{{else}}Invoice
          To{{/if}}</p>
        <p class="corp-bold">{{invoice.billedTo.name}}</p>
        {{#if invoice.billedTo.street}}<p>{{invoice.billedTo.street}}</p>{{/if}}
        {{#if invoice.billedTo.city}}<p>{{invoice.billedTo.city}}{{#if invoice.billedTo.state}},
          {{invoice.billedTo.state}}{{/if}} {{invoice.billedTo.pincode}}</p>{{/if}}
        {{#if invoice.billedTo.gstin}}<p>GSTIN: {{invoice.billedTo.gstin}}</p>{{/if}}
      </div>
      <div class="corp-address-right">
        <p class="corp-label">Contact Person</p>
        {{#if invoice.contact.name}}<p class="corp-bold">{{invoice.contact.name}}</p>{{/if}}
        {{#if invoice.contact.email}}<p>{{invoice.contact.email}}</p>{{/if}}
        {{#if invoice.contact.phone}}<p>{{invoice.contact.phone}}</p>{{/if}}
      </div>
    </div>

    {{!-- Invoice No / Invoice Date --}}
    <div class="corp-meta-row">
      <div class="corp-meta-left">
        <span class="corp-label">{{#if
          invoice.customLabels.invoiceNumber}}{{invoice.customLabels.invoiceNumber}}{{else}}Invoice No.{{/if}}</span>
        <span class="corp-bold">{{invoice.invoiceNumber}}</span>
      </div>
      <div class="corp-meta-right">
        <span class="corp-label">{{#if
          invoice.customLabels.invoiceDate}}{{invoice.customLabels.invoiceDate}}{{else}}Invoice Date{{/if}}</span>
        <span class="corp-bold">{{formateShortDateWithOffset invoice.invoiceDate invoice.ownerOffset}}</span>
      </div>
    </div>

    {{!-- Due Date (if present) --}}
    {{#if invoice.dueDate}}
    <div class="corp-meta-row corp-meta-row-sub">
      <div class="corp-meta-left">
        <span class="corp-label">{{#if invoice.customLabels.dueDate}}{{invoice.customLabels.dueDate}}{{else}}Due
          Date{{/if}}</span>
        <span class="corp-bold">{{formateShortDateWithOffset invoice.dueDate invoice.ownerOffset}}</span>
      </div>
      <div class="corp-meta-right">
        <span class="corp-label">Status</span>
        <span>{{> InvoiceStatus invoice }}</span>
      </div>
    </div>
    {{/if}}

    {{!-- Line Items Table --}}
    <table class="corp-item-table">
      <thead>
        <tr>
          <th class="col-sno">S.no.</th>
          <th class="col-desc">Description</th>
          <th class="col-unit text-right">Unit</th>
          <th class="col-rate text-right">Rate</th>
          {{#if invoice.finalTotal.discount}}<th class="col-disc text-right">Discount</th>{{/if}}
          <th class="col-amount text-right">Amount</th>
        </tr>
      </thead>
      <tbody>
        {{#each invoice.items}}
        <tr>
          <td class="text-center">{{increment @index}}</td>
          <td>
            <span class="item-name">{{name}}</span>
            {{#if ../advanceOptions.showSkuInInvoice}}{{#if sku}}<span class="item-sku"> (SKU:
              {{sku}})</span>{{/if}}{{/if}}
            {{#if ../derived.showInlineHsn}}{{#if hsn}}<span class="item-sku"> (HSN/SAC: {{hsn}})</span>{{/if}}{{/if}}
            {{#if description}}
            <div class="item-desc">
              {{> MarkdownViewer (prepareMarkdownViewerData description) }}
            </div>
            {{/if}}
          </td>
          <td class="text-right">{{quantity}}</td>
          <td class="text-right">{{../invoice.customCurrencySymbol}} {{rate}}</td>
          {{#if ../invoice.finalTotal.discount}}<td class="text-right">{{discountLabel}}</td>{{/if}}
          <td class="text-right">{{../invoice.customCurrencySymbol}} {{amount}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    {{!-- Totals Section --}}
    <div class="corp-totals-area">
      {{!-- HSN/SAC on left --}}
      <div class="corp-totals-left">
        {{#each invoice.items}}
        {{#if hsn}}
        <p class="hsn-note">HSN/SAC Code - {{hsn}}</p>
        {{/if}}
        {{/each}}
      </div>

      {{!-- Totals on right --}}
      <div class="corp-totals-right">
        <div class="corp-total-line">
          <span class="corp-total-label corp-bold">{{#if
            invoice.customLabels.subTotal}}{{invoice.customLabels.subTotal}}{{else}}Sub Total{{/if}}</span>
          <span class="corp-total-value">{{invoice.customCurrencySymbol}} {{#if
            invoice.finalTotal.subTotal}}{{invoice.finalTotal.subTotal}}{{else}}{{invoice.subTotal}}{{/if}}</span>
        </div>

        {{#if invoice.finalTotal.discount}}
        <div class="corp-total-line">
          <span class="corp-total-label">Discount</span>
          <span class="corp-total-value">- {{invoice.customCurrencySymbol}} {{invoice.finalTotal.discount}}</span>
        </div>
        {{/if}}

        {{#if invoice.finalTotal.cgst}}
        <div class="corp-total-line">
          <span class="corp-total-label">CGST</span>
          <span class="corp-total-value">{{invoice.customCurrencySymbol}} {{invoice.finalTotal.cgst}}</span>
        </div>
        {{/if}}

        {{#if invoice.finalTotal.sgst}}
        <div class="corp-total-line">
          <span class="corp-total-label">{{#if mapped.visibility.isUtgst}}UTGST{{else}}SGST{{/if}}</span>
          <span class="corp-total-value">{{invoice.customCurrencySymbol}} {{invoice.finalTotal.sgst}}</span>
        </div>
        {{/if}}

        {{#if invoice.finalTotal.igst}}
        <div class="corp-total-line">
          <span class="corp-total-label">IGST</span>
          <span class="corp-total-value">{{invoice.customCurrencySymbol}} {{invoice.finalTotal.igst}}</span>
        </div>
        {{/if}}

        <div class="corp-total-line corp-grand-total">
          <span class="corp-total-label">{{#if
            invoice.customLabels.total}}{{invoice.customLabels.total}}{{else}}Total{{/if}}</span>
          <span class="corp-total-value">{{invoice.customCurrencySymbol}} {{invoice.finalTotal.total}}</span>
        </div>
      </div>
    </div>

    {{!-- Total in words --}}
    {{#if invoice.customLabels.totalInWordsValue}}
    <div class="corp-total-words">
      <span class="corp-bold">{{#if
        invoice.customLabels.totalInWords}}{{invoice.customLabels.totalInWords}}{{else}}Total (in words){{/if}}:</span>
      {{invoice.customLabels.totalInWordsValue}}
    </div>
    {{/if}}

    {{!-- Notes --}}
    {{#if invoice.notes}}
    <div class="corp-notes-section">
      <h3>{{#if invoice.customLabels.notes}}{{invoice.customLabels.notes}}{{else}}Notes{{/if}}</h3>
      {{> MarkdownViewer (prepareMarkdownViewerData invoice.notes) }}
    </div>
    {{/if}}

    {{!-- Terms & Conditions + Authorized Signatory --}}
    <div class="corp-terms-sig-row">
      <div class="corp-terms-block">
        {{#if invoice.terms.0.terms.length}}
        <h3>{{#if invoice.customLabels.terms}}{{invoice.customLabels.terms}}{{else}}Terms & Conditions{{/if}}</h3>
        <ul>
          {{#each invoice.terms.0.terms}}
          <li>{{this}}</li>
          {{/each}}
        </ul>
        {{/if}}
      </div>
      <div class="corp-signatory">
        {{#if invoice.billedBy.signature}}
        <img class="corp-sig-img" src="{{invoice.billedBy.signature}}" alt="Signature" />
        {{/if}}
        <p class="corp-bold">Authorized Signatory</p>
      </div>
    </div>

    {{!-- Bank Details --}}
    {{#if mapped.visibility.showBankAccount}}
    <div class="corp-bank-section">
      <h3>Bank Details</h3>
      <div class="corp-bank-grid">
        <div class="corp-bank-item">
          <span class="corp-bank-label">Beneficiary Name</span>
          <span class="corp-bank-value">{{#if
            invoice.bankAccount.holderName}}{{invoice.bankAccount.holderName}}{{else}}{{invoice.billedBy.name}}{{/if}}</span>
        </div>
        {{#if invoice.bankAccount.accountNo}}
        <div class="corp-bank-item">
          <span class="corp-bank-label">Current A/c</span>
          <span class="corp-bank-value">{{invoice.bankAccount.accountNo}}</span>
        </div>
        {{/if}}
        {{#if invoice.bankAccount.ifsc}}
        <div class="corp-bank-item">
          <span class="corp-bank-label">IFSC</span>
          <span class="corp-bank-value">{{invoice.bankAccount.ifsc}}</span>
        </div>
        {{/if}}
        {{#if invoice.bankAccount.bankName}}
        <div class="corp-bank-item">
          <span class="corp-bank-label">Bank Name</span>
          <span class="corp-bank-value">{{invoice.bankAccount.bankName}}</span>
        </div>
        {{/if}}
      </div>
    </div>
    {{/if}}

    {{!-- Regulatory / Dark Footer Bar --}}
    <div class="corp-reg-bar">
      {{#if invoice.invoiceSubTitle}}
      <p>{{invoice.invoiceSubTitle}}</p>
      {{/if}}
    </div>

    {{!-- Bottom Footer --}}
    <div class="corp-bottom-footer">
      <div class="corp-footer-left">
        {{#if invoice.billedBy.logo}}
        <img src="{{invoice.billedBy.logo}}" alt="{{invoice.billedBy.name}}" class="corp-footer-logo" />
        {{/if}}
        <div class="corp-footer-info">
          <p class="corp-bold">{{invoice.billedBy.name}}</p>
          <p>{{invoice.billedBy.street}}{{#if invoice.billedBy.city}}, {{invoice.billedBy.city}}{{/if}} -
            {{invoice.billedBy.pincode}}</p>
        </div>
      </div>
      <div class="corp-footer-right">
        {{#if invoice.billedBy.gstin}}<p>GSTIN: {{invoice.billedBy.gstin}}</p>{{/if}}
        {{#if invoice.billedBy.cin}}<p>CIN: {{invoice.billedBy.cin}}</p>{{/if}}
      </div>
    </div>

  </div>

  {{!-- Letterhead Footer --}}
  <div class="no-dibella corp-letterhead-footer{{#unless invoice.letterHeadFooter}} is-empty{{/unless}}">
    {{#if invoice.letterHeadFooter}}
    <img src="{{invoice.letterHeadFooter}}" alt="Letterhead footer" data-ceres-height="letterhead-footer" />
    {{else}}
    <img alt="Letterhead footer" data-ceres-height="letterhead-footer" />
    {{/if}}
  </div>
</div>